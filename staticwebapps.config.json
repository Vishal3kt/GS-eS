{
    "globalHeaders": {
        "X-Frame-Options": "DENY",
        "X-Content-Type-Options": "nosniff"
    },
    "mimeTypes": {
        ".json": "application/json",
        ".js": "application/javascript",
        ".css": "text/css"
    },
    "navigationFallback": {
        "rewrite": "/index.html",
        "exclude": [
            "/assets/*",
            "/*.css",
            "/*.js",
            "/*.png",
            "/*.jpg",
            "/*.jpeg",
            "/*.gif",
            "/*.ico",
            "/*.svg",
            "/*.woff",
            "/*.woff2",
            "/*.ttf",
            "/*.eot",
            "/*.map"
        ]
    },
    "trailingSlash": "never"
}